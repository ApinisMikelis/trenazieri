{
  "name": "trenazieri",
  "version": "1.0.0",
  "description": "WordPress Theme",
  "main": "index.js",
  "scripts": {
    "sass:compile": "sass assets/src/scss/main.scss:assets/dist/css/sass-output.css --no-source-map",
    "css:concat": "concat -o assets/dist/css/combined.css assets/dist/css/sass-output.css assets/src/css/main.css",
    "css:minify": "sass assets/dist/css/combined.css:assets/dist/css/app.min.css --style compressed --no-source-map",
    "clean:dist": "rimraf assets/dist/css/sass-output.css assets/dist/css/combined.css assets/dist/css/main.css",
    "compile": "npm-run-all sass:compile css:concat css:minify clean:dist",
    "watch:sass-compile": "sass --watch assets/src/scss/main.scss:assets/dist/css/sass-output.css --no-source-map",
    "watch:concat": "npm-run-all --sequential css:concat",
    "watch:minify-clean": "npm-run-all --sequential css:minify clean:dist",
    "watch": "npm-run-all --parallel watch:sass-compile 'watch:concat' watch:minify-clean"
  },
  "keywords": [
    "wordpress",
    "scss"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concat": "^1.0.3",
    "gulp": "^5.0.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.0",
    "sass": "^1.77.8"
  }
}
