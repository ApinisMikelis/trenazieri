{
  "name": "trenazieri",
  "version": "1.0.0",
  "description": "WordPress Theme",
  "main": "index.js",
  "scripts": {
    "sass:compile": "sass assets/src/scss/main.scss assets/dist/css/sass-output.css",
    "css:concat": "concat -o assets/dist/css/combined.css assets/dist/css/sass-output.css",
    "css:minify": "sass assets/dist/css/combined.css assets/dist/css/combined.min.css --style compressed",
    "clean:dist": "rimraf assets/dist/css/sass-output.css",
    "compile": "npm-run-all sass:compile css:concat css:minify clean:dist",
    "watch:sass-compile": "sass --watch assets/src/scss/main.scss:assets/dist/css/sass-output.css",
    "watch:concat": "npm-run-all --sequential css:concat",
    "watch:minify-clean": "npm-run-all --sequential css:minify clean:dist",
    "build": "gulp",
    "watch": "gulp watchAll"
  },
  "keywords": [
    "wordpress",
    "scss"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concat": "^1.0.3",
    "gulp": "^5.0.1",
    "gulp-concat": "^2.6.1",
    "gulp-css": "^0.1.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "gulp-uglify": "^3.0.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.0",
    "sass": "^1.77.8"
  }
}
